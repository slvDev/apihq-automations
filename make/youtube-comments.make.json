{
  "name": "YouTube comments (apihq skeleton)",
  "flow": [
    {
      "id": 1,
      "module": "http:ActionSendData",
      "version": 3,
      "parameters": {
        "handleErrors": false,
        "useNewZLibDeCompress": true
      },
      "mapper": {
        "url": "https://api.apify.com/v2/acts/apihq~youtube-comments-scraper/run-sync-get-dataset-items",
        "serializeUrl": false,
        "method": "post",
        "headers": [
          {
            "name": "Authorization",
            "value": "Bearer YOUR_APIFY_TOKEN"
          }
        ],
        "qs": [],
        "bodyType": "raw",
        "parseResponse": true,
        "timeout": "300",
        "shareCookies": false,
        "ca": "",
        "rejectUnauthorized": true,
        "followRedirect": true,
        "useQuerystring": false,
        "gzip": true,
        "useMtls": false,
        "contentType": "application/json",
        "data": "{\n  \"videoUrls\": [\"dQw4w9WgXcQ\"],\n  \"maxComments\": 200,\n  \"sort\": \"top\",\n  \"includeReplies\": false\n}",
        "followAllRedirects": false,
        "authUser": "",
        "authPass": ""
      },
      "metadata": {
        "designer": {
          "x": 0,
          "y": 0,
          "name": "Get comments"
        }
      }
    },
    {
      "id": 2,
      "module": "builtin:BasicFeeder",
      "version": 1,
      "parameters": {},
      "mapper": {
        "array": "{{1.data}}"
      },
      "metadata": {
        "designer": {
          "x": 300,
          "y": 0,
          "name": "One bundle per comment"
        }
      }
    },
    {
      "id": 3,
      "module": "builtin:BasicRouter",
      "version": 1,
      "parameters": {},
      "mapper": null,
      "metadata": {
        "designer": {
          "x": 600,
          "y": 0
        }
      },
      "routes": [
        {
          "flow": [
            {
              "id": 4,
              "module": "util:SetVariables",
              "version": 1,
              "parameters": {},
              "filter": {
                "name": "Comment rows (billed)",
                "conditions": [
                  [
                    {
                      "a": "{{2.success}}",
                      "b": "true",
                      "o": "boolean:equal"
                    }
                  ]
                ]
              },
              "mapper": {
                "variables": [
                  {
                    "name": "video_id",
                    "value": "{{2.video_id}}"
                  },
                  {
                    "name": "author",
                    "value": "{{2.author_name}}"
                  },
                  {
                    "name": "text",
                    "value": "{{2.text}}"
                  },
                  {
                    "name": "like_count",
                    "value": "{{2.like_count}}"
                  }
                ],
                "scope": "roundtrip"
              },
              "metadata": {
                "designer": {
                  "x": 900,
                  "y": -150,
                  "name": "Comment row"
                }
              }
            }
          ]
        },
        {
          "flow": [
            {
              "id": 5,
              "module": "util:SetVariables",
              "version": 1,
              "parameters": {},
              "filter": {
                "name": "Failure rows (not billed)",
                "conditions": [
                  [
                    {
                      "a": "{{2.success}}",
                      "b": "false",
                      "o": "boolean:equal"
                    }
                  ]
                ]
              },
              "mapper": {
                "variables": [
                  {
                    "name": "video_id",
                    "value": "{{2.video_id}}"
                  },
                  {
                    "name": "code",
                    "value": "{{2.code}}"
                  },
                  {
                    "name": "request_id",
                    "value": "{{2.request_id}}"
                  }
                ],
                "scope": "roundtrip"
              },
              "metadata": {
                "designer": {
                  "x": 900,
                  "y": 150,
                  "name": "Failure row"
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "metadata": {
    "instant": false,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": {
      "orphans": []
    }
  }
}